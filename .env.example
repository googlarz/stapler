DATABASE_URL=postgres://paperclip:paperclip@localhost:5432/paperclip
PORT=3100
SERVE_UI=false
BETTER_AUTH_SECRET=<generate-with-openssl-rand-hex-32>

# ── Semantic memory search (optional) ───────────────────────────────────────
# When configured, memories are embedded at save time and search uses cosine
# similarity instead of pg_trgm. Excellent for German and other morphologically
# rich languages. Leave everything blank to use pg_trgm keyword search.
#
# Pick ONE provider:
#
# Option A — OpenAI text-embedding-3-small (default, 1536 dims, cloud)
#   Best multilingual quality, ~$0.02 per million tokens.
# STAPLER_EMBEDDING_PROVIDER=openai
# OPENAI_API_KEY=sk-...
#
# Option B — Local Ollama (qwen3-embedding:8b, 4096 dims, fully offline)
#   Pull the model first:  ollama pull qwen3-embedding:8b
#   Needs ~8 GB free RAM. Strong multilingual performance, zero per-token cost.
# STAPLER_EMBEDDING_PROVIDER=ollama
# STAPLER_OLLAMA_HOST=http://localhost:11434
# STAPLER_OLLAMA_EMBEDDING_MODEL=qwen3-embedding:8b
#
# Do not switch providers mid-deployment without re-embedding — stored vectors
# from one provider are incomparable with queries from the other.
OPENAI_API_KEY=
