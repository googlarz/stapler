DATABASE_URL=postgres://paperclip:paperclip@localhost:5432/paperclip
PORT=3100
SERVE_UI=false
BETTER_AUTH_SECRET=<generate-with-openssl-rand-hex-32>

# Optional: OpenAI API key for semantic memory search (text-embedding-3-small).
# When set, memories are embedded at save time and search uses cosine similarity
# instead of pg_trgm. Excellent for German-language content (compound words,
# declensions). Leave blank to use pg_trgm keyword search (the safe default).
OPENAI_API_KEY=
